NODE_ENV=production
PORT=10000
# Public URL including path if you use unified host (e.g. nginx path routing to this service)
PUBLIC_API_URL=https://api.pickfoo.in/restaurant
# Set when this process receives paths like /restaurant/api/v1 (no nginx path strip). Leave empty if nginx strips /restaurant before proxying.
# API_BASE_PATH=/restaurant
# TRUST_PROXY=1

DATABASE_URL=

JWT_SECRET=
REFRESH_TOKEN_SECRET=

# Production web origin; local Next.js owner app: http://localhost:3003
CLIENT_URL=https://restaurant.pickfoo.in

# AWS S3 Settings
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PRESIGNED_URL_EXPIRY=3600
MAX_FILE_SIZE=5242880
CLOUDFRONT_URL=

# Email Settings
EMAIL_USER=
EMAIL_PASS=

# Unified API host: admin app is served under /admin
ADMIN_BACKEND_URL=https://api.pickfoo.in/admin

LOGIN_EMAIL=
LOGIN_PASSWORD=
